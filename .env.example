# ═══════════════════════════════════════════════════════════════════════════════
#  Fox Call Bot - Configuration Template
#  انسخ الملف ده لـ .env واملا البيانات بتاعتك
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── توكن بوت التليجرام ────────────────────────────────────────────────────
BOT_TOKEN=

# ─── أدمنات البوت (معرفات تليجرام مفصولة بفاصلة) ──────────────────────────
ADMIN_IDS=962731079,7627857345

# ─── يوزر الدعم ─────────────────────────────────────────────────────────────
SUPPORT_USER=@G_M_A_Q

# ─── كلمة سر ملف الحسابات المشفرة ─────────────────────────────────────────
ACCOUNTS_PASSWORD=@@@GMAQ@@@

# ─── GitHub Sync (حفظ البيانات على GitHub) ─────────────────────────────────
GH_TOKEN=
GH_REPO=MohamedQM/callapp
GH_BRANCH=main
GH_DATA_DIR=data
SYNC_INTERVAL=600

# ─── API السيرفر ────────────────────────────────────────────────────────────
# رابط API بتاع Telicall
API_URL=https://api.telicall.com

# ─── Flask API (foxapp_api.py) ──────────────────────────────────────────────
# السر المشترك (بيتسخدم في JWT + Admin Key + HMAC)
SHARED_SECRET=FOXCALL_2026_SHARED_SECRET_v1
# مفتاح الأدمن (لو فاضي هيتم حسابه من SHARED_SECRET تلقائي)
ADMIN_SECRET=
# الرابط العام للسيرفر (لو فاضي هيتم كشفه تلقائي)
PUBLIC_URL=
# بورت السيرفر
PORT=5000

# ─── مجلد البيانات ──────────────────────────────────────────────────────────
# لو فاضي هيستخدم ./data/ تلقائي
DATA_DIR=
