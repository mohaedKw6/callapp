# ═══════════════════════════════════════════════════════════════════
# Fox Call Bot - Environment Configuration (EXAMPLE)
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️ IMPORTANT: .env contains secrets — NEVER commit to public repos!
# ⚠️ On Railway: Set these as Environment Variables instead
# ═══════════════════════════════════════════════════════════════════

# ─── Bot Token (REQUIRED) ─────────────────────────────────────────
# Get from @BotFather on Telegram: /token @F0X_CALL_BOT
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ─── Admin IDs (comma-separated Telegram user IDs) ────────────────
ADMIN_IDS=962731079,7627857345

# ─── Support Contact ──────────────────────────────────────────────
SUPPORT_USER=@G_M_A_Q

# ─── Telicall API ─────────────────────────────────────────────────
API_URL=https://api.telicall.com

# ─── Data Directory (for persistent storage) ──────────────────────
# On Railway/cloud: set to a mounted volume path (e.g. /app/data)
# On local dev: leave empty to use ./data/ automatically
DATA_DIR=/app/data

# ─── Shared Secret (for JWT signing & request verification) ───────
SHARED_SECRET=FOXCALL_2026_SHARED_SECRET_v1

# ─── Admin Secret (for admin API endpoints) ───────────────────────
# If not set, derived from SHARED_SECRET automatically
ADMIN_SECRET=

# ─── Fox App API Server ──────────────────────────────────────────
PORT=8080
PUBLIC_URL=https://your-railway-app.up.railway.app

# ─── Accounts Password (for Dan.json encryption) ──────────────────
ACCOUNTS_PASSWORD=@@@GMAQ@@@

# ─── GitHub Sync (for persistent data storage via GitHub API) ─────
GH_TOKEN=YOUR_GITHUB_TOKEN_HERE
GH_REPO=mohaedKw6/callapp
SYNC_INTERVAL=600
